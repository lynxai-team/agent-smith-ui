{
    "compilerOptions": {
        "target": "esnext",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "lib": [
            "ES2022"
        ],
        "types": [
            "node",
            "vite/client"
        ],
        "allowJs": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": false,
        "sourceMap": false
    },
    "include": [
        "src/bin/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}